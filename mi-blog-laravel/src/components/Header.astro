---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="header-inner">
		<a href="/" class="site-title" aria-label={SITE_TITLE}>
			<img src="/logo-laravel-v2.svg" alt={SITE_TITLE} class="site-logo" width="200" height="50" />
		</a>
		<nav>
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/roadmap">Roadmap</HeaderLink>
			<HeaderLink href="/curso">Curso</HeaderLink>
			<HeaderLink href="/about">Sobre</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		background: #ffffff;
		border-bottom: 3px solid #FF2D20;
		position: sticky;
		top: 0;
		z-index: 100;
		box-shadow: 0 2px 12px rgba(0,0,0,0.07);
	}

	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.site-title {
		display: flex;
		align-items: center;
		text-decoration: none;
		transition: opacity 0.2s;
	}

	.site-title:hover {
		opacity: 0.85;
		text-decoration: none;
	}

	.site-logo {
		height: 56px;
		width: auto;
		display: block;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	nav :global(a) {
		padding: 0.5em 0.875em;
		color: #374151;
		border-radius: 6px;
		font-weight: 500;
		font-size: 0.95em;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}

	nav :global(a:hover) {
		background: rgba(255, 45, 32, 0.08);
		color: #FF2D20;
		text-decoration: none;
	}

	nav :global(a.active) {
		color: #FF2D20;
		font-weight: 700;
		background: rgba(255, 45, 32, 0.1);
	}

	@media (max-width: 600px) {
		.site-logo { height: 38px; }
		.header-inner { padding: 0 0.875em; height: 54px; }
		nav :global(a) {
			padding: 0.45em 0.625em;
			font-size: 0.875em;
		}
	}

	@media (max-width: 360px) {
		.site-logo { height: 32px; }
		nav :global(a) { padding: 0.4em 0.5em; font-size: 0.82em; }
	}
</style>
