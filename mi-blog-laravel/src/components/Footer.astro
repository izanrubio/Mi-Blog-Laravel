---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<span class="footer-title">{SITE_TITLE}</span>
			<p class="footer-desc">El blog de referencia para desarrolladores PHP hispanohablantes que usan Laravel.</p>
		</div>
		<div class="footer-links">
			<div class="footer-col">
				<strong>Navegación</strong>
				<a href="/">Inicio</a>
				<a href="/blog">Blog</a>
				<a href="/about">Sobre</a>
			</div>
			<div class="footer-col">
				<strong>Categorías</strong>
				<a href="/blog">Instalación</a>
				<a href="/blog">Errores</a>
				<a href="/blog">Guías</a>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} {SITE_TITLE} — Hecho con ❤️ para la comunidad Laravel hispanohablante</p>
	</div>
</footer>

<style>
	footer {
		background: #1a1a2e;
		color: #a0aec0;
		margin-top: auto;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3em 1.5em 2em;
		display: flex;
		justify-content: space-between;
		gap: 3em;
	}

	.footer-brand {
		flex: 1;
		max-width: 320px;
	}

	.footer-title {
		display: block;
		color: #FF2D20;
		font-weight: 800;
		font-size: 1.15em;
		margin-bottom: 0.75em;
	}

	.footer-desc {
		font-size: 0.875em;
		line-height: 1.6;
		color: #718096;
		margin: 0;
	}

	.footer-links {
		display: flex;
		gap: 3em;
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	.footer-col strong {
		color: #e2e8f0;
		font-size: 0.8em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.25em;
	}

	.footer-col a {
		color: #718096;
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.15s;
	}

	.footer-col a:hover {
		color: #FF2D20;
		text-decoration: none;
	}

	.footer-bottom {
		border-top: 1px solid #2d3748;
		text-align: center;
		padding: 1.25em 1.5em;
		font-size: 0.8em;
		color: #4a5568;
	}

	.footer-bottom p { margin: 0; }

	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			gap: 2em;
			padding: 2em 1em 1.5em;
		}

		.footer-links {
			gap: 2em;
		}

		.footer-brand {
			max-width: 100%;
		}
	}
</style>
