---
import BaseHead from '../components/BaseHead.astro';
import { cursoData, totalLecciones } from '../data/curso';

type Props = {
  title: string;
  description: string;
  moduloActual: string;
  leccionActual: string;
};

const { title, description, moduloActual, leccionActual } = Astro.props;

const allLessonsOrdered = cursoData.flatMap(m =>
  m.lecciones.map(l => `${m.slug}/${l.slug}`)
);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div class="curso-wrapper">

      <!-- ── Sidebar ─────────────────────────────────── -->
      <aside class="sidebar" id="sidebar">

        <div class="sidebar-top">
          <a href="/curso" class="curso-brand">
            <div class="brand-logo">{`{L}`}</div>
            <div class="brand-text">
              <div class="brand-title">Laravel desde cero</div>
              <div class="brand-sub">Curso gratuito en español</div>
            </div>
          </a>
        </div>

        <nav class="sidebar-nav" id="sidebar-nav">
          {cursoData.map(modulo => {
            const isCurrentModule = modulo.slug === moduloActual;
            return (
              <div class="mod-group" data-mod={modulo.slug}>
                <button
                  class:list={['mod-trigger', { 'mod-trigger--open': isCurrentModule }]}
                  data-mod={modulo.slug}
                  aria-expanded={isCurrentModule ? 'true' : 'false'}
                >
                  <span class="mod-name">{modulo.number}. {modulo.title}</span>

                </button>
                <div class:list={['mod-lessons', { 'mod-lessons--open': isCurrentModule }]}>
                  {modulo.lecciones.map((lec, i) => {
                    const isActive = isCurrentModule && lec.slug === leccionActual;
                    const lessonId = `${modulo.slug}/${lec.slug}`;
                    return (
                      <a
                        href={`/curso/${modulo.slug}/${lec.slug}`}
                        class:list={['lec-link', { 'lec-link--active': isActive }]}
                        data-lesson-id={lessonId}
                      >
                        <span class="lec-num">{i + 1}</span>
                        <span class="lec-name">{lec.title}</span>
                      </a>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </nav>

        <div class="sidebar-footer">
          <div class="prog-label">
            <span id="prog-count">0</span> de {totalLecciones} completadas
          </div>
          <div class="prog-bg">
            <div class="prog-fill" id="prog-fill" style="width:0%"></div>
          </div>
          <a href="/blog" class="back-blog">

            Volver al blog
          </a>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="sidebar-overlay" id="sidebar-overlay"></div>

      <!-- ── Main content ───────────────────────────── -->
      <div class="curso-main">
        <!-- Mobile header -->
        <div class="mobile-bar">
          <button class="menu-btn" id="menu-btn" aria-label="Abrir menú">Menú</button>
          <a href="/curso" class="mobile-brand">{`{L}`} Laravel desde cero</a>
        </div>

        <slot />
      </div>
    </div>

    <script is:inline define:vars={{ totalLecciones, allLessonsOrdered }}>
      const STORAGE_KEY = 'curso-completado';

      function getCompleted() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
        catch { return []; }
      }

      function isLocked(lessonId) {
        if (lessonId === allLessonsOrdered[0]) return false;
        const idx = allLessonsOrdered.indexOf(lessonId);
        if (idx <= 0) return false;
        return !getCompleted().includes(allLessonsOrdered[idx - 1]);
      }

      function updateProgress() {
        const completed = getCompleted();
        const count = completed.length;
        const pct = Math.round((count / totalLecciones) * 100);
        const progCount = document.getElementById('prog-count');
        const progFill = document.getElementById('prog-fill');
        if (progCount) progCount.textContent = count;
        if (progFill) progFill.style.width = pct + '%';

        document.querySelectorAll('.lec-link[data-lesson-id]').forEach(link => {
          const id = link.dataset.lessonId;
          const locked = isLocked(id);

          link.classList.toggle('lec-link--locked', locked);
          if (locked) {
            link.dataset.href = link.getAttribute('href') || '';
            link.removeAttribute('href');
          } else if (!link.getAttribute('href') && link.dataset.href) {
            link.setAttribute('href', link.dataset.href);
          }
        });
      }

      updateProgress();
      window.addEventListener('curso:progress-updated', updateProgress);

      // Sidebar toggle (mobile)
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      const menuBtn = document.getElementById('menu-btn');

      function openSidebar() {
        sidebar.classList.add('sidebar--open');
        overlay.classList.add('overlay--visible');
        document.body.style.overflow = 'hidden';
      }
      function closeSidebar() {
        sidebar.classList.remove('sidebar--open');
        overlay.classList.remove('overlay--visible');
        document.body.style.overflow = '';
      }

      menuBtn?.addEventListener('click', openSidebar);
      overlay?.addEventListener('click', closeSidebar);

      // Module expand/collapse
      document.querySelectorAll('.mod-trigger').forEach(btn => {
        btn.addEventListener('click', () => {
          const mod = btn.dataset.mod;
          const lessons = document.querySelector(`.mod-lessons[data-mod="${mod}"]`) ||
            btn.nextElementSibling;
          const isOpen = lessons.classList.contains('mod-lessons--open');
          lessons.classList.toggle('mod-lessons--open', !isOpen);
          btn.classList.toggle('mod-trigger--open', !isOpen);
          btn.setAttribute('aria-expanded', !isOpen ? 'true' : 'false');
        });
      });

      document.querySelectorAll('.mod-group').forEach(group => {
        const mod = group.dataset.mod;
        const lessons = group.querySelector('.mod-lessons');
        if (lessons) lessons.dataset.mod = mod;
      });
    </script>
  </body>
</html>

<style>
  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    background: #f9fafb;
    color: #111827;
  }

  .curso-wrapper {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ─────────────────────────────────── */
  .sidebar {
    width: 280px;
    min-width: 280px;
    background: #111827;
    color: #e5e7eb;
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: sticky;
    top: 0;
    overflow: hidden;
    transition: transform 0.25s ease;
    z-index: 100;
    flex-shrink: 0;
  }

  .sidebar-top {
    padding: 1.25rem 1.25rem 1rem;
    border-bottom: 1px solid #1f2937;
    flex-shrink: 0;
  }

  .curso-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }

  .curso-brand:hover { opacity: 0.85; text-decoration: none; }

  .brand-logo {
    width: 38px;
    height: 38px;
    background: #FF2D20;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 900;
    color: white;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .brand-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: #f9fafb;
    line-height: 1.2;
  }

  .brand-sub {
    font-size: 0.7rem;
    color: #6b7280;
    margin-top: 1px;
  }

  /* Nav */
  .sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 0;
    scrollbar-width: thin;
    scrollbar-color: #374151 transparent;
  }

  .sidebar-nav::-webkit-scrollbar { width: 4px; }
  .sidebar-nav::-webkit-scrollbar-thumb { background: #374151; border-radius: 2px; }

  /* Module */
  .mod-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.25rem;
    background: none;
    border: none;
    color: #9ca3af;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition: color 0.15s, background 0.15s;
  }

  .mod-trigger:hover { color: #f9fafb; background: #1f2937; }
  .mod-trigger--open { color: #f9fafb; }
  .mod-name { flex: 1; line-height: 1.3; }

  /* Lessons collapse */
  .mod-lessons {
    display: none;
    flex-direction: column;
  }

  .mod-lessons--open { display: flex; }

  .lec-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem 0.5rem 2.75rem;
    text-decoration: none;
    color: #6b7280;
    font-size: 0.78rem;
    transition: color 0.15s, background 0.15s;
    border-left: 2px solid transparent;
  }

  .lec-link:hover { color: #e5e7eb; background: #1f2937; text-decoration: none; }

  .lec-link--active {
    color: #FF2D20;
    background: rgba(255, 45, 32, 0.08);
    border-left-color: #FF2D20;
  }

  .lec-num {
    font-size: 0.68rem;
    font-weight: 700;
    color: #4b5563;
    min-width: 14px;
    flex-shrink: 0;
  }

  .lec-link--active .lec-num { color: #FF2D20; }

  .lec-name { flex: 1; line-height: 1.35; }

  .lec-link--locked {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  .lec-link--locked .lec-num { color: #374151; }

  /* Footer */
  .sidebar-footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid #1f2937;
    flex-shrink: 0;
  }

  .prog-label {
    font-size: 0.72rem;
    color: #6b7280;
    margin-bottom: 0.4rem;
  }

  .prog-bg {
    height: 4px;
    background: #1f2937;
    border-radius: 99px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .prog-fill {
    height: 100%;
    background: #FF2D20;
    border-radius: 99px;
    transition: width 0.4s ease;
  }

  .back-blog {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #6b7280;
    font-size: 0.78rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-blog:hover { color: #e5e7eb; text-decoration: none; }

  /* ── Main content ─────────────────────────────── */
  .curso-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    background: #fff;
    min-height: 100vh;
  }

  /* Mobile bar (hidden on desktop) */
  .mobile-bar {
    display: none;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1.25rem;
    background: #111827;
    border-bottom: 1px solid #1f2937;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .menu-btn {
    background: none;
    border: none;
    color: #9ca3af;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .menu-btn:hover { color: #f9fafb; }

  .mobile-brand {
    font-size: 0.875rem;
    font-weight: 700;
    color: #f9fafb;
    text-decoration: none;
  }

  /* Overlay */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 99;
  }

  .overlay--visible { display: block; }

  /* ── Mobile ───────────────────────────────────── */
  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      height: 100%;
      transform: translateX(-100%);
    }

    .sidebar--open { transform: translateX(0); }

    .mobile-bar { display: flex; }

    .curso-main { min-height: 100vh; }
  }
</style>
