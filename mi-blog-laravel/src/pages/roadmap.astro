---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { roadmap, totalNodes } from '../data/roadmap';

const title = 'Hoja de Ruta de Laravel en Español — De cero a experto';
const description = 'Aprende Laravel paso a paso con esta hoja de ruta visual. Desde PHP básico hasta Laravel avanzado, con recursos en español para cada etapa.';

const difficultyColor: Record<string, string> = {
  'Básico':     '#10b981',
  'Intermedio': '#f59e0b',
  'Avanzado':   '#FF2D20',
};
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />

    <main>
      <!-- Page header -->
      <div class="page-header">
        <div class="header-badge">Hoja de ruta</div>
        <h1>Aprende <span class="accent">Laravel</span> de cero a experto</h1>
        <p class="header-desc">
          Sigue este roadmap para aprender Laravel de forma estructurada.
          Haz clic en cada tema para ver más detalles y marcar tu progreso.
        </p>

        <!-- Progress bar -->
        <div class="progress-wrap">
          <div class="progress-header">
            <span id="progress-label">0 de {totalNodes} temas completados</span>
            <button id="reset-btn" class="reset-btn" title="Resetear progreso">Resetear progreso</button>
          </div>
          <div class="progress-bar-bg">
            <div class="progress-bar-fill" id="progress-bar" style="width:0%"></div>
          </div>
        </div>
      </div>

      <!-- Roadmap levels -->
      <div class="roadmap">
        {roadmap.map((level, li) => (
          <div class="level-block">

            <!-- Connector line above (except first) -->
            {li > 0 && <div class="connector" style={`border-color:${level.color}`}></div>}

            <!-- Level badge -->
            <div class="level-badge" style={`background:${level.color}`}>
              <span class="level-num">Nivel {level.number}</span>
              <span class="level-sep">·</span>
              <span class="level-title-text">{level.title}</span>
            </div>

            <!-- Nodes grid -->
            <div class="nodes-grid">
              {level.nodes.map(node => (
                <div
                  class="node-card"
                  data-id={node.id}
                  style={`--level-color:${level.color};--level-bg:${level.bgColor};--level-border:${level.borderColor}`}
                >
                  <!-- Card header (clickable) -->
                  <button class="node-trigger" aria-expanded="false">
                    <span class="node-icon">{node.icon}</span>
                    <span class="node-name">{node.title}</span>
                    <svg class="chevron" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
                    </svg>
                  </button>

                  <!-- Expandable body -->
                  <div class="node-body">
                    <div class="node-body-inner">
                      <p class="node-desc">{node.description}</p>
                      <div class="node-meta">
                        <span class="meta-time">
                          <svg viewBox="0 0 20 20" fill="currentColor" width="13" height="13"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                          {node.estimatedTime}
                        </span>
                        <span
                          class="meta-diff"
                          style={`background:${difficultyColor[node.difficulty]}22;color:${difficultyColor[node.difficulty]};border-color:${difficultyColor[node.difficulty]}44`}
                        >
                          {node.difficulty}
                        </span>
                      </div>
                      <div class="node-actions">
                        {node.blogSlug && (
                          <a href={`/blog/${node.blogSlug}/`} class="btn-article" target="_blank">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/></svg>
                            Ver artículo
                          </a>
                        )}
                        <button class="btn-complete" data-id={node.id}>
                          <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                          <span>Marcar como completado</span>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </main>

    <!-- Reset confirm modal -->
    <div id="reset-modal" class="modal-overlay" aria-hidden="true">
      <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <p id="modal-title" class="modal-text">¿Resetear todo el progreso?</p>
        <div class="modal-actions">
          <button id="modal-cancel" class="modal-btn modal-btn--cancel">Cancelar</button>
          <button id="modal-confirm" class="modal-btn modal-btn--confirm">Aceptar</button>
        </div>
      </div>
    </div>

    <Footer />

    <script is:inline define:vars={{ totalNodes }}>
      const STORAGE_KEY = 'roadmap_completed';

      function getCompleted() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
        catch { return []; }
      }

      function saveCompleted(arr) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(arr));
      }

      function updateProgress() {
        const completed = getCompleted();
        const count = completed.length;
        const pct = Math.round((count / totalNodes) * 100);
        document.getElementById('progress-label').textContent =
          count + ' de ' + totalNodes + ' temas completados';
        document.getElementById('progress-bar').style.width = pct + '%';
      }

      function applyCompleted() {
        const completed = getCompleted();
        document.querySelectorAll('.node-card').forEach(card => {
          const id = card.dataset.id;
          const btn = card.querySelector('.btn-complete');
          const isDone = completed.includes(id);
          card.classList.toggle('node-card--done', isDone);
          if (btn) btn.querySelector('span').textContent =
            isDone ? 'Completado ✓' : 'Marcar como completado';
        });
        updateProgress();
      }

      // Expand / collapse
      document.querySelectorAll('.node-trigger').forEach(trigger => {
        trigger.addEventListener('click', () => {
          const card = trigger.closest('.node-card');
          const isOpen = card.classList.contains('node-card--open');
          // Close all others
          document.querySelectorAll('.node-card--open').forEach(c => {
            c.classList.remove('node-card--open');
            c.querySelector('.node-trigger').setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            card.classList.add('node-card--open');
            trigger.setAttribute('aria-expanded', 'true');
          }
        });
      });

      // Mark complete
      document.querySelectorAll('.btn-complete').forEach(btn => {
        btn.addEventListener('click', e => {
          e.stopPropagation();
          const id = btn.dataset.id;
          const completed = getCompleted();
          const idx = completed.indexOf(id);
          if (idx === -1) completed.push(id);
          else completed.splice(idx, 1);
          saveCompleted(completed);
          applyCompleted();
        });
      });

      // Reset modal
      const modal = document.getElementById('reset-modal');
      document.getElementById('reset-btn').addEventListener('click', () => {
        modal.setAttribute('aria-hidden', 'false');
        modal.classList.add('modal-overlay--open');
      });
      document.getElementById('modal-cancel').addEventListener('click', () => {
        modal.setAttribute('aria-hidden', 'true');
        modal.classList.remove('modal-overlay--open');
      });
      document.getElementById('modal-confirm').addEventListener('click', () => {
        modal.setAttribute('aria-hidden', 'true');
        modal.classList.remove('modal-overlay--open');
        saveCompleted([]);
        applyCompleted();
      });
      modal.addEventListener('click', e => {
        if (e.target === modal) {
          modal.setAttribute('aria-hidden', 'true');
          modal.classList.remove('modal-overlay--open');
        }
      });

      // Init
      applyCompleted();
    </script>
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5rem 1rem 5rem;
    box-sizing: border-box;
  }

  /* ── Page header ─────────────────────────────────── */
  .page-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .header-badge {
    display: inline-block;
    background: rgba(255, 45, 32, 0.1);
    color: #FF2D20;
    padding: 0.3em 1em;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    border: 1px solid rgba(255, 45, 32, 0.2);
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: #111827;
    margin: 0 0 0.75rem;
    line-height: 1.15;
  }

  .accent { color: #FF2D20; }

  .header-desc {
    color: #6b7280;
    font-size: 1rem;
    max-width: 560px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  /* ── Progress ────────────────────────────────────── */
  .progress-wrap {
    max-width: 480px;
    margin: 0 auto;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    gap: 1rem;
  }

  #progress-label {
    font-size: 0.875rem;
    color: #374151;
    font-weight: 600;
  }

  .reset-btn {
    font-size: 0.75rem;
    color: #9ca3af;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0;
    text-decoration: underline;
    white-space: nowrap;
  }

  .reset-btn:hover { color: #FF2D20; }

  .progress-bar-bg {
    height: 8px;
    background: #e5e7eb;
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #FF2D20, #ff6b63);
    border-radius: 99px;
    transition: width 0.4s ease;
  }

  /* ── Roadmap ─────────────────────────────────────── */
  .roadmap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .level-block {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Connector line between levels */
  .connector {
    width: 2px;
    height: 2.5rem;
    border-left: 2px dashed;
    opacity: 0.4;
  }

  /* Level badge */
  .level-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.5em 1.25em;
    border-radius: 99px;
    color: white;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .level-num { font-weight: 800; }
  .level-sep { opacity: 0.6; }
  .level-title-text { font-weight: 600; }

  /* ── Nodes grid ──────────────────────────────────── */
  .nodes-grid {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 0;
  }

  /* ── Node card ───────────────────────────────────── */
  .node-card {
    border: 1.5px solid var(--level-border);
    border-radius: 12px;
    background: #fff;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .node-card:hover {
    border-color: var(--level-color);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .node-card--done {
    background: #f0fdf4;
    border-color: #86efac;
  }

  .node-card--done .node-name {
    text-decoration: line-through;
    color: #6b7280;
  }

  /* Trigger button */
  .node-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.125rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
  }

  .node-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .node-name {
    flex: 1;
    font-size: 0.925rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.3;
  }

  .chevron {
    flex-shrink: 0;
    color: #9ca3af;
    transition: transform 0.25s ease;
  }

  .node-card--open .chevron {
    transform: rotate(180deg);
  }

  /* Expandable body */
  .node-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .node-card--open .node-body {
    max-height: 400px;
  }

  .node-body-inner {
    padding: 0 1.125rem 1.125rem;
    border-top: 1px solid #f3f4f6;
  }

  .node-card--done .node-body-inner {
    border-top-color: #bbf7d0;
  }

  .node-desc {
    font-size: 0.875rem;
    color: #4b5563;
    line-height: 1.65;
    margin: 0.875rem 0 0.875rem;
  }

  /* Meta row */
  .node-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 0.875rem;
  }

  .meta-time {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-size: 0.78rem;
    color: #6b7280;
    font-weight: 500;
  }

  .meta-diff {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 99px;
    border: 1px solid;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Action buttons */
  .node-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn-article {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.4em 0.875em;
    border-radius: 8px;
    background: #f3f4f6;
    color: #374151;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    border: 1px solid #e5e7eb;
  }

  .btn-article:hover {
    background: var(--level-bg);
    color: var(--level-color);
    border-color: var(--level-border);
    text-decoration: none;
  }

  .btn-complete {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.4em 0.875em;
    border-radius: 8px;
    background: #f3f4f6;
    color: #374151;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    border: 1px solid #e5e7eb;
  }

  .btn-complete:hover {
    background: #dcfce7;
    color: #15803d;
    border-color: #86efac;
  }

  .node-card--done .btn-complete {
    background: #dcfce7;
    color: #15803d;
    border-color: #86efac;
  }

  /* ── Tablet (600px+) ─────────────────────────────── */
  @media (min-width: 600px) {
    .nodes-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    main { padding: 3rem 1.5rem 5rem; }
  }

  /* ── Desktop (860px+) ────────────────────────────── */
  @media (min-width: 860px) {
    .nodes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Reset modal ─────────────────────────────────── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay--open {
    display: flex;
  }

  .modal-box {
    background: #1f2937;
    border-radius: 14px;
    padding: 1.75rem 1.5rem 1.5rem;
    width: min(340px, 90vw);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    animation: modal-in 0.18s ease;
  }

  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }

  .modal-text {
    color: #f9fafb;
    font-size: 1rem;
    font-weight: 500;
    text-align: center;
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .modal-btn {
    padding: 0.55em 1.25em;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s;
  }

  .modal-btn:hover { opacity: 0.85; }

  .modal-btn--cancel {
    background: #374151;
    color: #f9fafb;
  }

  .modal-btn--confirm {
    background: #06b6d4;
    color: #fff;
  }
</style>
