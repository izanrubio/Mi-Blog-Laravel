---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Color de acento por categoría (basado en el primer tag)
const tagColor: Record<string, { bg: string; text: string; dot: string }> = {
	'instalacion':      { bg: '#EFF6FF', text: '#1D4ED8', dot: '#3B82F6' },
	'errores':          { bg: '#FFF7ED', text: '#C2410C', dot: '#F97316' },
	'debug':            { bg: '#FFF7ED', text: '#C2410C', dot: '#F97316' },
	'conceptos':        { bg: '#F0FDF4', text: '#15803D', dot: '#22C55E' },
	'arquitectura':     { bg: '#F0FDF4', text: '#15803D', dot: '#22C55E' },
	'rendimiento':      { bg: '#FDF4FF', text: '#7E22CE', dot: '#A855F7' },
	'optimizacion':     { bg: '#FDF4FF', text: '#7E22CE', dot: '#A855F7' },
	'comparativa':      { bg: '#FFFBEB', text: '#B45309', dot: '#F59E0B' },
	'testing':          { bg: '#F0FDF4', text: '#15803D', dot: '#22C55E' },
	'seguridad':        { bg: '#FFF1F2', text: '#BE123C', dot: '#F43F5E' },
	'api':              { bg: '#EFF6FF', text: '#1D4ED8', dot: '#3B82F6' },
	'autenticacion':    { bg: '#FFF1F2', text: '#BE123C', dot: '#F43F5E' },
	'base-de-datos':    { bg: '#ECFDF5', text: '#065F46', dot: '#10B981' },
	'migraciones':      { bg: '#ECFDF5', text: '#065F46', dot: '#10B981' },
	'default':          { bg: '#F3F4F6', text: '#374151', dot: '#6B7280' },
};

function getTagStyle(tags: string[]) {
	for (const tag of tags) {
		if (tagColor[tag]) return tagColor[tag];
	}
	return tagColor['default'];
}

const categories = [
	{ name: 'Todos',        slug: '' },
	{ name: 'Instalación',  slug: 'instalacion' },
	{ name: 'Errores',      slug: 'errores' },
	{ name: 'Conceptos',    slug: 'conceptos' },
	{ name: 'Comparativas', slug: 'comparativa' },
	{ name: 'Optimización', slug: 'optimizacion' },
];

const searchData = posts.map(p => ({
	id:    p.id,
	title: p.data.title,
	desc:  p.data.description,
	tags:  (p.data.tags ?? []),
}));

const pageTitle = `Blog — ${SITE_TITLE}`;
const pageDesc  = 'Todos los artículos sobre Laravel: instalación, errores comunes, guías de conceptos, comparativas y optimización. En español.';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<main>

			<!-- Cabecera + buscador -->
			<div class="page-header">
				<div class="header-top">
					<h1>Blog</h1>
					<p id="result-count"><strong>{posts.length}</strong> artículos sobre Laravel</p>
				</div>

				<div class="search-wrapper">
					<svg class="search-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
						<path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
					</svg>
					<input
						id="search-input"
						type="search"
						placeholder="Buscar… ej: CORS, Eloquent, deploy"
						autocomplete="off"
						spellcheck="false"
					/>
					<button id="search-clear" class="clear-btn" aria-label="Limpiar" hidden>
						<svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
							<path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
						</svg>
					</button>
				</div>

				<!-- Filtros de categoría -->
				<div class="cat-filters" id="cat-filters">
					{categories.map(cat => (
						<button
							class="cat-pill"
							data-cat={cat.slug}
						>
							{cat.name}
						</button>
					))}
				</div>
			</div>

			<!-- Grid de cards -->
			<div class="posts-grid" id="posts-list">
				{posts.map((post, i) => {
					const tags   = post.data.tags ?? [];
					const style  = getTagStyle(tags);
					const isFirst = i === 0;
					return (
						<article
							class={`post-card${isFirst ? ' post-card--featured' : ''}`}
							data-id={post.id}
							data-tags={(post.data.tags ?? []).join(',')}
						>
							<a href={`/blog/${post.id}/`} class="card-link">

								<!-- Banda de color superior -->
								<div class="card-stripe" style={`background:${style.bg}`}>
									{tags.length > 0 && (
										<span class="card-category" style={`color:${style.text}`}>
											<span class="cat-dot" style={`background:${style.dot}`}></span>
											{tags[0]}
										</span>
									)}
								</div>

								<!-- Cuerpo de la card -->
								<div class="card-body">
									<h2 class="card-title">{post.data.title}</h2>
									<p class="card-desc">{post.data.description}</p>
								</div>

								<!-- Footer de la card -->
								<div class="card-footer">
									<time datetime={post.data.pubDate.toISOString()} class="card-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<span class="card-read">Leer →</span>
								</div>

							</a>
						</article>
					);
				})}
			</div>

			<!-- Sin resultados -->
			<div id="no-results" class="no-results" hidden>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0016.803 16.803z"/>
				</svg>
				<p>Sin resultados para "<strong id="no-results-query"></strong>"</p>
				<span>Prueba: <em>eloquent, cors, migraciones, deploy…</em></span>
			</div>

		</main>
		<Footer />

		<script is:inline define:vars={{ searchData }}>
			const input    = document.getElementById('search-input');
			const clearBtn = document.getElementById('search-clear');
			const grid     = document.getElementById('posts-list');
			const noRes    = document.getElementById('no-results');
			const noResQ   = document.getElementById('no-results-query');
			const count    = document.getElementById('result-count');
			const items    = grid.querySelectorAll('.post-card');
			const pills    = document.querySelectorAll('.cat-pill');
			const total    = items.length;

			let activeCategory = '';

			function normalize(s) {
				return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
			}

			function applyFilters() {
				const q      = normalize(input.value.trim());
				const tokens = q ? q.split(/\s+/).filter(Boolean) : [];
				let visible  = 0;

				items.forEach(el => {
					const post = searchData.find(p => p.id === el.dataset.id);
					if (!post) { el.hidden = true; return; }

					// Filtro de categoría
					const catOk = !activeCategory || post.tags.includes(activeCategory);
					if (!catOk) { el.hidden = true; return; }

					// Filtro de texto
					const hay  = normalize(`${post.title} ${post.desc} ${post.tags.join(' ')}`);
					const textOk = tokens.length === 0 || tokens.every(t => hay.includes(t));

					el.hidden = !textOk;
					if (textOk) visible++;
				});

				clearBtn.hidden = !q;

				if (visible === 0) {
					noRes.hidden = false;
					noResQ.textContent = q || activeCategory;
					count.innerHTML = `<strong>0</strong> resultados`;
				} else {
					noRes.hidden = true;
					if (q) {
						count.innerHTML = `<strong>${visible}</strong> resultado${visible !== 1 ? 's' : ''} para "<em>${input.value.trim()}</em>"`;
					} else if (activeCategory) {
						count.innerHTML = `<strong>${visible}</strong> artículo${visible !== 1 ? 's' : ''} en esta categoría`;
					} else {
						count.innerHTML = `<strong>${total}</strong> artículos sobre Laravel`;
					}
				}
			}

			function setCategory(slug) {
				activeCategory = slug;
				pills.forEach(p => {
					p.classList.toggle('cat-pill--active', p.dataset.cat === slug);
				});
				// Actualizar URL sin recargar
				const url = new URL(location.href);
				if (slug) url.searchParams.set('cat', slug);
				else url.searchParams.delete('cat');
				history.replaceState({}, '', url);
				applyFilters();
			}

			pills.forEach(pill => {
				pill.addEventListener('click', () => setCategory(pill.dataset.cat));
			});

			input.addEventListener('input', applyFilters);
			clearBtn.addEventListener('click', () => { input.value = ''; input.focus(); applyFilters(); });

			// Leer params iniciales de la URL
			const params = new URLSearchParams(location.search);
			const q0   = params.get('q');
			const cat0 = params.get('cat');

			if (q0)   { input.value = q0; }
			if (cat0) { activeCategory = cat0; pills.forEach(p => p.classList.toggle('cat-pill--active', p.dataset.cat === cat0)); }
			else      { pills[0]?.classList.add('cat-pill--active'); }

			if (q0 || cat0) applyFilters();
		</script>
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.5rem 1rem 4rem;
		box-sizing: border-box;
	}

	/* ── Header + search ─────────────────────────────── */
	.page-header {
		margin-bottom: 2.25rem;
	}

	.header-top {
		margin-bottom: 1.25rem;
	}

	.header-top h1 {
		font-size: 2rem;
		color: #111827;
		margin: 0 0 0.2rem;
		letter-spacing: -0.025em;
	}

	#result-count {
		font-size: 0.875rem;
		color: #6b7280;
		margin: 0;
	}

	#result-count em { font-style: normal; color: #374151; }

	.search-wrapper {
		position: relative;
		max-width: 480px;
	}

	.search-icon {
		position: absolute;
		left: 0.875rem;
		top: 50%;
		transform: translateY(-50%);
		width: 17px;
		height: 17px;
		color: #9ca3af;
		pointer-events: none;
	}

	#search-input {
		width: 100%;
		padding: 0.7rem 2.5rem 0.7rem 2.75rem;
		font-size: 0.9rem;
		font-family: inherit;
		border: 1.5px solid #e5e7eb;
		border-radius: 10px;
		background: #f9fafb;
		color: #111827;
		outline: none;
		transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
		-webkit-appearance: none;
	}

	#search-input::placeholder { color: #9ca3af; }
	#search-input::-webkit-search-cancel-button { display: none; }

	#search-input:focus {
		border-color: #FF2D20;
		background: #fff;
		box-shadow: 0 0 0 3px rgba(255,45,32,0.08);
	}

	.clear-btn {
		position: absolute;
		right: 0.625rem;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border: none;
		background: #e5e7eb;
		color: #6b7280;
		border-radius: 50%;
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}

	.clear-btn:hover { background: #FF2D20; color: white; }

	/* ── Category pills ─────────────────────────────── */
	.cat-filters {
		display: flex;
		gap: 0.5rem;
		margin-top: 1.25rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
		padding-bottom: 2px;
	}

	.cat-filters::-webkit-scrollbar { display: none; }

	.cat-pill {
		padding: 0.45rem 1rem;
		border-radius: 99px;
		border: 1.5px solid #e5e7eb;
		background: #f9fafb;
		color: #6b7280;
		font-size: 0.8rem;
		font-weight: 600;
		font-family: inherit;
		cursor: pointer;
		transition: all 0.15s;
		text-transform: capitalize;
		white-space: nowrap;
		flex-shrink: 0;
		min-height: 36px;
	}

	.cat-pill:hover {
		border-color: #FF2D20;
		color: #FF2D20;
		background: #fff5f5;
	}

	.cat-pill--active {
		background: #FF2D20;
		border-color: #FF2D20;
		color: white;
	}

	.cat-pill--active:hover {
		background: #CC2419;
		border-color: #CC2419;
		color: white;
	}

	/* ── Grid ────────────────────────────────────────── */
	.posts-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.875rem;
	}

	@media (min-width: 560px) {
		main { padding: 2rem 1.5rem 4.5rem; }
		.posts-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
		.post-card--featured { grid-column: span 2; }
	}

	@media (min-width: 900px) {
		main { padding: 2.5rem 1.5rem 5rem; }
		.posts-grid { grid-template-columns: repeat(3, 1fr); gap: 1.125rem; }
		.post-card--featured { grid-column: span 2; }
	}

	/* ── Card ────────────────────────────────────────── */
	.post-card {
		border-radius: 14px;
		border: 1px solid #e5e7eb;
		background: #fff;
		overflow: hidden;
		transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
		display: flex;
		flex-direction: column;
	}

	.post-card[hidden] { display: none; }

	.post-card:hover {
		border-color: #FF2D20;
		box-shadow: 0 8px 28px rgba(0,0,0,0.09);
		transform: translateY(-3px);
	}

	/* Card destacada — solo span en tablet+ */
	.post-card--featured {
		grid-column: span 1;
	}

	.post-card--featured .card-stripe {
		padding: 1.125rem 1.375rem;
	}

	.post-card--featured .card-body {
		padding: 1.375rem;
	}

	.post-card--featured .card-title {
		font-size: 1.2rem;
	}

	.post-card--featured .card-desc {
		-webkit-line-clamp: 3;
	}

	/* ── Card link ───────────────────────────────────── */
	.card-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		text-decoration: none;
		color: inherit;
	}

	/* ── Stripe (banda superior de color) ────────────── */
	.card-stripe {
		padding: 0.875rem 1.125rem;
		display: flex;
		align-items: center;
	}

	.card-category {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
	}

	.cat-dot {
		display: inline-block;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	/* ── Card body ───────────────────────────────────── */
	.card-body {
		padding: 1rem 1.125rem 0.75rem;
		flex: 1;
	}

	.card-title {
		font-size: 0.975rem;
		font-weight: 700;
		color: #111827;
		margin: 0 0 0.5rem;
		line-height: 1.35;
		letter-spacing: -0.01em;
		transition: color 0.15s;
	}

	.post-card:hover .card-title { color: #FF2D20; }

	.card-desc {
		font-size: 0.825rem;
		color: #6b7280;
		margin: 0;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ── Card footer ─────────────────────────────────── */
	.card-footer {
		padding: 0.75rem 1.125rem;
		border-top: 1px solid #f3f4f6;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.card-date {
		font-size: 0.75rem;
		color: #9ca3af;
	}

	.card-read {
		font-size: 0.75rem;
		font-weight: 700;
		color: #FF2D20;
		opacity: 0;
		transition: opacity 0.15s;
	}

	.post-card:hover .card-read { opacity: 1; }

	/* ── No results ──────────────────────────────────── */
	.no-results {
		text-align: center;
		padding: 5rem 1rem;
		color: #9ca3af;
	}

	.no-results svg {
		width: 44px;
		height: 44px;
		margin: 0 auto 1rem;
		color: #d1d5db;
	}

	.no-results p {
		font-size: 1rem;
		color: #374151;
		margin: 0 0 0.375rem;
	}

	.no-results p strong { color: #FF2D20; }
	.no-results span { font-size: 0.85rem; }

	/* ── Responsive ──────────────────────────────────── */
	@media (max-width: 580px) {
		main { padding: 1.5rem 1rem 4rem; }
		.search-wrapper { max-width: 100%; }
		.page-header { margin-bottom: 1.5rem; }
	}
</style>
