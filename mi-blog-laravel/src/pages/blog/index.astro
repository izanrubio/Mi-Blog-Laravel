---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = `Blog — ${SITE_TITLE}`;
const pageDesc = 'Todos los artículos sobre Laravel: instalación, errores comunes, guías de conceptos, comparativas y optimización. En español.';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Blog</h1>
				<p>Todos los artículos sobre Laravel — <strong>{posts.length}</strong> publicaciones</p>
			</div>

			<div class="posts-list">
				{posts.map((post) => (
					<article class="post-item">
						<a href={`/blog/${post.id}/`} class="post-link">
							<div class="post-meta">
								<time datetime={post.data.pubDate.toISOString()}>
									<FormattedDate date={post.data.pubDate} />
								</time>
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="tag-list">
										{post.data.tags.slice(0, 3).map(tag => (
											<span class="tag">{tag}</span>
										))}
									</div>
								)}
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-desc">{post.data.description}</p>
							<span class="read-more">Leer artículo →</span>
						</a>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 2.5em 1em 4em;
	}

	.page-header {
		margin-bottom: 2.5em;
		padding-bottom: 1.5em;
		border-bottom: 2px solid #f3f4f6;
	}

	.page-header h1 {
		font-size: 2em;
		margin-bottom: 0.25em;
		color: #111827;
	}

	.page-header p {
		color: #6b7280;
		margin: 0;
		font-size: 0.95em;
	}

	.posts-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.post-item {
		border-bottom: 1px solid #f3f4f6;
	}

	.post-link {
		display: block;
		padding: 1.75em 0;
		text-decoration: none;
		color: inherit;
		transition: padding-left 0.2s;
	}

	.post-link:hover {
		padding-left: 0.5em;
		text-decoration: none;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-wrap: wrap;
		margin-bottom: 0.6em;
	}

	.post-meta time {
		font-size: 0.8em;
		color: #9ca3af;
	}

	.tag-list {
		display: flex;
		gap: 0.375em;
		flex-wrap: wrap;
	}

	.tag {
		display: inline-block;
		background: rgba(255, 45, 32, 0.1);
		color: #CC2419;
		padding: 2px 8px;
		border-radius: 99px;
		font-size: 0.7em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		border: 1px solid rgba(255, 45, 32, 0.2);
	}

	.post-title {
		font-size: 1.2em;
		color: #111827;
		margin: 0 0 0.4em;
		line-height: 1.35;
		transition: color 0.2s;
	}

	.post-link:hover .post-title {
		color: #FF2D20;
	}

	.post-desc {
		font-size: 0.9em;
		color: #6b7280;
		margin: 0 0 0.75em;
		line-height: 1.6;
	}

	.read-more {
		font-size: 0.85em;
		color: #FF2D20;
		font-weight: 600;
	}

	@media (max-width: 600px) {
		main { padding: 1.5em 1em 3em; }
	}
</style>
