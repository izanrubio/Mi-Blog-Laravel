---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Calcular tiempo estimado de lectura
const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Artículos relacionados: mismas tags o recientes
const allPosts = (await getCollection('blog'))
	.filter(p => p.id !== post.id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postTags = post.data.tags ?? [];
const related = allPosts
	.filter(p => p.data.tags?.some(t => postTags.includes(t)))
	.slice(0, 3);

const relatedPosts = related.length >= 2 ? related : allPosts.slice(0, 3);
---

<BlogPost {...post.data} readingTime={readingTime} relatedPosts={relatedPosts}>
	<Content />
</BlogPost>
